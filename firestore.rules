rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users ─────────────────────────────────────────────────────────
    // Users can read/write their own document. Admins can read any user.
    // Users CANNOT change their own role field.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if (isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role))
        || isAdmin();
      allow delete: if isAdmin();

      // User sub-collections: addresses, paymentMethods
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }

      match /paymentMethods/{methodId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Products ──────────────────────────────────────────────────────
    // Publicly readable, only admin can write.
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Categories ────────────────────────────────────────────────────
    // Publicly readable, only admin can write.
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Orders ────────────────────────────────────────────────────────
    // Users can read their own orders. Admins can read/update all.
    // Only the server (Admin SDK) should create orders — no client creates.
    match /orders/{orderId} {
      allow read: if isAuthenticated() &&
        (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if false; // Server-side only via Admin SDK
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Reviews ───────────────────────────────────────────────────────
    // Publicly readable. Authenticated users can create.
    // Only the author or an admin can delete. No updates.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Settings ──────────────────────────────────────────────────────
    // Publicly readable (e.g. free shipping threshold), admin-only write.
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Tax Rates ─────────────────────────────────────────────────────
    // Publicly readable (checkout needs them), admin-only write.
    match /taxRates/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Shipping Rates ────────────────────────────────────────────────
    // Publicly readable (checkout needs them), admin-only write.
    match /shippingRates/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Processed Webhook Events (for idempotency) ────────────────────
    // Server-side only. No client access.
    match /processedEvents/{eventId} {
      allow read, write: if false;
    }
  }
}
